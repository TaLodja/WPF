<UserControl x:Class="IP_adressPresentation.View.UserControls.PointsColumn"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IP_adressPresentation.View.UserControls"
             xmlns:userControls="clr-namespace:IP_adressPresentation.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="140" d:DesignWidth="35">
    <Grid>
		<Grid.RowDefinitions>
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
		</Grid.RowDefinitions>
		<userControls:Point Grid.Row="0" />
		<userControls:Point Grid.Row="1" />
		<userControls:Point Grid.Row="2" />
		<userControls:Point Grid.Row="3" />
	</Grid>
</UserControl>
